// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum ProjectMemberRole {
  OWNER
  EDITOR
  VIEWER
}

enum PhaseStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ToolApplicationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum AttachmentType {
  IMAGE
  PDF
  LINK
  OTHER
}

enum TipoProyecto {
  STARTUP
  PRODUCTO_DIGITAL
  INVESTIGACION_UX
  PROYECTO_INTERNO
  SERVICIO
  PROCESO
  OTRO
}

enum EtapaProyecto {
  IDEA
  EXPLORACION
  VALIDACION
  DESARROLLO
  LANZAMIENTO
  CRECIMIENTO
  MADUREZ
}

enum TaskPriority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum TaskAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  ASSIGNED
  PRIORITY_CHANGED
  MOVED
  DELETED
}

enum AreaProfesional {
  FRONTEND
  BACKEND
  FULLSTACK
  QA
  DEVOPS
  UX
  DISENO
  PRODUCTO
  DATOS
  MANAGEMENT
  OTRO
}

enum Senioridad {
  JUNIOR
  SEMI_SENIOR
  SENIOR
  LEAD
  PRINCIPAL
}

enum TipoDisponibilidad {
  FULL_TIME
  PART_TIME
  FREELANCE
  CONSULTOR
}

enum NivelCompetencia {
  BASICO
  INTERMEDIO
  AVANZADO
}

enum RequirementType {
  FUNCTIONAL
  NON_FUNCTIONAL
}

enum RequirementSubtype {
  PERFORMANCE
  SECURITY
  USABILITY
  SCALABILITY
  RELIABILITY
  AVAILABILITY
  MAINTAINABILITY
  COMPATIBILITY
}

enum RequirementPriority {
  MUST_HAVE
  SHOULD_HAVE
  COULD_HAVE
  WONT_HAVE
}

enum RequirementStatus {
  DRAFT
  IN_REVIEW
  VALIDATED
  REJECTED
  DEFERRED
}

enum Moneda {
  // Internacionales
  USD
  EUR
  // Latinoamérica
  ARS
  BRL
  CLP
  COP
  MXN
  PEN
  UYU
  PYG
  BOB
  VES
  CRC
  DOP
  GTQ
  HNL
  NIO
  PAB
  CUP
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  VENCIDO
}

enum EstadoCobro {
  PENDIENTE
  COBRADO
  VENCIDO
}

enum TipoRecurso {
  PERSONA
  SERVIDOR
  LICENCIA
  HERRAMIENTA
  SERVICIO
  OTRO
}

enum FrecuenciaCosto {
  UNICO
  SEMANAL
  MENSUAL
  ANUAL
}

// ─── USUARIO ─────────────────────────────────────────────────────────────────

model User {
  id             Int                 @id @default(autoincrement())
  email          String              @unique
  password       String
  nombre         String
  isSuperAdmin   Boolean             @default(false)
  activo         Boolean             @default(true)
  // Perfil profesional
  telefono       String?
  zonaHoraria    String?
  area           AreaProfesional?
  senioridad     Senioridad?
  disponibilidad TipoDisponibilidad?
  horasSemanales Int?
  lenguajes      String[]
  frameworks     String[]
  basesDeDatos   String[]
  herramientas   String[]
  bio            String?             @db.Text
  avatarUrl      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // Relaciones auth
  userRoles       UserRole[]
  userPermissions UserPermission[]
  refreshTokens   RefreshToken[]

  // Relaciones proyecto
  ownedProjects         Project[]                    @relation("ProjectOwner")
  projectMemberships    ProjectMember[]
  toolApplications      ToolApplication[]            @relation("ToolApplicationCreator")
  toolAppNotes          ToolApplicationNote[]        @relation("NoteCreator")
  toolAppAttachments    ToolApplicationAttachment[]  @relation("AttachmentCreator")
  wikiPages             WikiPage[]
  userSkills            UserSkill[]
  requirementsCreated   Requirement[]                @relation("RequirementCreatedBy")
  requirementsUpdated   Requirement[]                @relation("RequirementUpdatedBy")

  // Relaciones tareas
  assignedTasks  Task[]           @relation("TaskAssignee")
  createdTasks   Task[]           @relation("TaskCreator")
  taskActivities TaskActivity[]

  @@index([activo])
}

// ─── HABILIDADES DE USUARIO ───────────────────────────────────────────────────

model UserSkill {
  id         Int              @id @default(autoincrement())
  userId     Int
  tecnologia String
  nivel      NivelCompetencia
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tecnologia])
  @@index([userId])
}

// ─── ROL ──────────────────────────────────────────────────────────────────────

model Role {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  nombre      String
  descripcion String?  @db.Text
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([activo])
}

// ─── PERMISO ──────────────────────────────────────────────────────────────────

model Permission {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  descripcion String?  @db.Text
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@index([activo])
}

// ─── ROL - PERMISO (Many-to-Many) ─────────────────────────────────────────────

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ─── USUARIO - ROL (Many-to-Many) ─────────────────────────────────────────────

model UserRole {
  userId Int
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ─── USUARIO - PERMISO (Overrides individuales) ───────────────────────────────

model UserPermission {
  id           Int        @id @default(autoincrement())
  userId       Int
  permissionId Int
  granted      Boolean
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

// ─── REFRESH TOKEN ────────────────────────────────────────────────────────────

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

// ─── FASE DE DISEÑO (Catálogo: 4 fases Double Diamond) ──────────────────────

model DesignPhase {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  nombre      String
  descripcion String   @db.Text
  orden       Int
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  categories    ToolCategory[]
  projectPhases ProjectPhase[]

  @@index([activo])
}

// ─── CATEGORÍA DE HERRAMIENTA (9 subcategorías) ─────────────────────────────

model ToolCategory {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  nombre      String
  descripcion String?  @db.Text
  phaseId     Int
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  phase DesignPhase       @relation(fields: [phaseId], references: [id])
  tools ToolCategoryTool[]

  @@index([phaseId])
  @@index([activo])
}

// ─── HERRAMIENTA DE DISEÑO (Catálogo: ~67 herramientas únicas) ──────────────

model Tool {
  id           Int      @id @default(autoincrement())
  codigo       String   @unique
  nombre       String
  descripcion  String   @db.Text
  comoSeUsa    String?  @db.Text
  ejemplo      String?  @db.Text
  cuandoUsarlo String?  @db.Text
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  categories       ToolCategoryTool[]
  toolApplications ToolApplication[]

  @@index([activo])
}

// ─── HERRAMIENTA - CATEGORÍA (Many-to-Many) ─────────────────────────────────

model ToolCategoryTool {
  toolId     Int
  categoryId Int
  tool       Tool         @relation(fields: [toolId], references: [id], onDelete: Cascade)
  category   ToolCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([toolId, categoryId])
  @@index([toolId])
  @@index([categoryId])
}

// ─── PROYECTO ───────────────────────────────────────────────────────────────

model Project {
  id          Int           @id @default(autoincrement())
  nombre      String
  descripcion String?       @db.Text
  tipo        TipoProyecto?
  etapa       EtapaProyecto?
  sector      String?
  contexto    String?        @db.Text
  estado      ProjectStatus @default(DRAFT)
  ownerId     Int
  presupuesto Float?
  moneda      Moneda?
  activo      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relaciones
  owner        User              @relation("ProjectOwner", fields: [ownerId], references: [id])
  members      ProjectMember[]
  phases       ProjectPhase[]
  wikiPages    WikiPage[]
  taskStatuses TaskStatus[]
  tasks        Task[]
  taskTags     TaskTag[]
  requirements Requirement[]
  recursos     RecursoProyecto[]
  ingresos     IngresoProyecto[]

  @@index([ownerId])
  @@index([estado])
  @@index([activo])
}

// ─── MIEMBRO DE PROYECTO ────────────────────────────────────────────────────

model ProjectMember {
  id        Int               @id @default(autoincrement())
  projectId Int
  userId    Int
  role      ProjectMemberRole
  // Ficha técnica del miembro en el proyecto
  cargo                  String?
  fechaIngreso           DateTime?
  horasSemanalesProyecto Int?
  responsabilidades      String[]
  entregables            String[]
  modulosAsignados       String[]
  participaDaily         Boolean  @default(false)
  participaPlanning      Boolean  @default(false)
  participaReview        Boolean  @default(false)
  participaRetro         Boolean  @default(false)
  objetivos              String?  @db.Text
  observaciones          String?  @db.Text
  accesos                Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relaciones
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

// ─── FASE DE PROYECTO ───────────────────────────────────────────────────────

model ProjectPhase {
  id        Int         @id @default(autoincrement())
  projectId Int
  phaseId   Int
  estado    PhaseStatus @default(NOT_STARTED)
  orden     Int
  notas     String?     @db.Text
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relaciones
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase            DesignPhase       @relation(fields: [phaseId], references: [id])
  toolApplications ToolApplication[]

  @@unique([projectId, phaseId, orden])
  @@index([projectId])
  @@index([phaseId])
}

// ─── APLICACIÓN DE HERRAMIENTA ──────────────────────────────────────────────

model ToolApplication {
  id             Int                   @id @default(autoincrement())
  projectPhaseId Int
  toolId         Int
  titulo         String
  structuredData Json                  @default("{}")
  estado         ToolApplicationStatus @default(PENDING)
  createdById    Int
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  // Relaciones
  projectPhase ProjectPhase              @relation(fields: [projectPhaseId], references: [id], onDelete: Cascade)
  tool         Tool                      @relation(fields: [toolId], references: [id])
  createdBy    User                      @relation("ToolApplicationCreator", fields: [createdById], references: [id])
  notes        ToolApplicationNote[]
  attachments  ToolApplicationAttachment[]
  tasks        Task[]

  @@index([projectPhaseId])
  @@index([toolId])
  @@index([createdById])
}

// ─── NOTA DE APLICACIÓN ─────────────────────────────────────────────────────

model ToolApplicationNote {
  id                Int      @id @default(autoincrement())
  toolApplicationId Int
  contenido         String   @db.Text
  createdById       Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relaciones
  toolApplication ToolApplication @relation(fields: [toolApplicationId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("NoteCreator", fields: [createdById], references: [id])

  @@index([toolApplicationId])
  @@index([createdById])
}

// ─── WIKI DE PROYECTO ───────────────────────────────────────────────────────

model WikiPage {
  id          Int      @id @default(autoincrement())
  projectId   Int
  parentId    Int?
  titulo      String
  contenido   String   @db.Text
  icono       String?
  banner      String?
  orden       Int      @default(0)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById Int

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User       @relation(fields: [createdById], references: [id])
  parent    WikiPage?  @relation("WikiTree", fields: [parentId], references: [id])
  children  WikiPage[] @relation("WikiTree")

  @@index([projectId])
  @@index([parentId])
}

// ─── ADJUNTO DE APLICACIÓN ──────────────────────────────────────────────────

model ToolApplicationAttachment {
  id                Int            @id @default(autoincrement())
  toolApplicationId Int
  nombre            String
  url               String
  tipo              AttachmentType
  size              Int?
  createdById       Int
  createdAt         DateTime       @default(now())

  // Relaciones
  toolApplication ToolApplication @relation(fields: [toolApplicationId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("AttachmentCreator", fields: [createdById], references: [id])

  @@index([toolApplicationId])
  @@index([createdById])
}

// ─── ESTADO DE TAREA (Columnas Kanban configurables por proyecto) ───────────

model TaskStatus {
  id        Int      @id @default(autoincrement())
  projectId Int
  nombre    String
  color     String
  orden     Int
  isFinal   Boolean  @default(false)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, nombre])
  @@index([projectId])
}

// ─── TAREA ──────────────────────────────────────────────────────────────────

model Task {
  id                Int          @id @default(autoincrement())
  projectId         Int
  parentId          Int?
  statusId          Int
  toolApplicationId Int?
  assigneeId        Int?
  createdById       Int
  titulo            String
  descripcion       String?      @db.Text
  prioridad         TaskPriority @default(MEDIUM)
  fechaInicio       DateTime?
  fechaVencimiento  DateTime?
  fechaCompletado   DateTime?
  estimacion        Float?
  orden             Int          @default(0)
  activo            Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relaciones
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent          Task?            @relation("TaskSubtasks", fields: [parentId], references: [id])
  children        Task[]           @relation("TaskSubtasks")
  status          TaskStatus       @relation(fields: [statusId], references: [id])
  toolApplication ToolApplication? @relation(fields: [toolApplicationId], references: [id])
  assignee        User?            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy       User             @relation("TaskCreator", fields: [createdById], references: [id])
  tags            TaskTagAssignment[]
  activities      TaskActivity[]

  @@index([projectId])
  @@index([parentId])
  @@index([statusId])
  @@index([assigneeId])
  @@index([createdById])
  @@index([activo])
}

// ─── ETIQUETA DE TAREA ──────────────────────────────────────────────────────

model TaskTag {
  id        Int      @id @default(autoincrement())
  projectId Int
  nombre    String
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments TaskTagAssignment[]

  @@unique([projectId, nombre])
  @@index([projectId])
}

// ─── TAREA - ETIQUETA (Many-to-Many) ────────────────────────────────────────

model TaskTagAssignment {
  taskId Int
  tagId  Int

  task Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  TaskTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([taskId])
  @@index([tagId])
}

// ─── ACTIVIDAD DE TAREA (Log automático) ────────────────────────────────────

model TaskActivity {
  id              Int        @id @default(autoincrement())
  taskId          Int
  userId          Int
  accion          TaskAction
  campoModificado String?
  valorAnterior   String?
  valorNuevo      String?
  createdAt       DateTime   @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
  @@index([createdAt])
}

// ─── REQUISITOS DEL PROYECTO ─────────────────────────────────────────────────

model Requirement {
  id                 Int                 @id @default(autoincrement())
  projectId          Int
  type               RequirementType
  subtype            RequirementSubtype?
  title              String
  description        String              @db.Text
  userStory          String?             @db.Text
  acceptanceCriteria String[]
  priority           RequirementPriority @default(MUST_HAVE)
  source             String?
  businessValue      String?             @db.Text
  status             RequirementStatus   @default(DRAFT)
  activo             Boolean             @default(true)
  createdById        Int
  updatedById        Int?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Relaciones
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("RequirementCreatedBy", fields: [createdById], references: [id])
  updatedBy User?   @relation("RequirementUpdatedBy", fields: [updatedById], references: [id])

  @@index([projectId])
  @@index([type])
  @@index([status])
  @@index([createdById])
}

// ─── RECURSO DE PROYECTO (Presupuesto) ──────────────────────────────────────

model RecursoProyecto {
  id             Int             @id @default(autoincrement())
  projectId      Int
  nombre         String
  tipo           TipoRecurso
  costo          Float
  frecuencia     FrecuenciaCosto
  cantidad       Int             @default(1)
  notas          String?         @db.Text
  activo         Boolean         @default(true)
  fechaInicio    DateTime?
  duracionMeses  Int             @default(1)
  esRecurrente   Boolean         @default(false)
  ivaPorcentaje  Float           @default(0)
  estadoPago     EstadoPago      @default(PENDIENTE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  adjuntos RecursoAdjunto[]

  @@index([projectId])
}

model RecursoAdjunto {
  id        Int            @id @default(autoincrement())
  recursoId Int
  nombre    String
  url       String
  tipo      AttachmentType
  size      Int?
  createdAt DateTime       @default(now())

  recurso RecursoProyecto @relation(fields: [recursoId], references: [id], onDelete: Cascade)

  @@index([recursoId])
}

// ─── INGRESO DE PROYECTO (Contabilidad) ─────────────────────────────────────

model IngresoProyecto {
  id               Int          @id @default(autoincrement())
  projectId        Int
  concepto         String
  monto            Float
  moneda           Moneda?
  empresaPagadora  String
  contactoPagadora String?
  emailPagadora    String?
  numeroFactura    String?
  fechaEmision     DateTime?
  fechaVencimiento DateTime
  fechaCobro       DateTime?
  estadoCobro      EstadoCobro  @default(PENDIENTE)
  notas            String?      @db.Text
  ivaPorcentaje    Float        @default(0)
  activo           Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  adjuntos IngresoAdjunto[]

  @@index([projectId])
  @@index([estadoCobro])
  @@index([fechaVencimiento])
}

model IngresoAdjunto {
  id        Int            @id @default(autoincrement())
  ingresoId Int
  nombre    String
  url       String
  tipo      AttachmentType
  size      Int?
  createdAt DateTime       @default(now())

  ingreso IngresoProyecto @relation(fields: [ingresoId], references: [id], onDelete: Cascade)

  @@index([ingresoId])
}
