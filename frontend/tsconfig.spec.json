{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": ["vitest/globals"],
    "paths": {
      "@core/*": ["./src/app/core/*"],
      "@pages/*": ["./src/app/Pages/*"],
      "@shared/*": ["./src/app/shared/*"]
    }
  },
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}
